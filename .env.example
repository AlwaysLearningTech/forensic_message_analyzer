# Anthropic Claude Configuration
# For Azure AI: set AI_ENDPOINT to your Azure AI Model Catalog endpoint
# For direct Anthropic API: leave AI_ENDPOINT blank (default)
AI_API_KEY=your-api-key-here
# Two-model setup. AI_BATCH_MODEL handles per-message batch classification
# (cheap, high-volume); AI_SUMMARY_MODEL writes the executive narrative
# after batches complete (higher quality, single call). The legacy single
# AI_MODEL setting has been removed — set both below.
# Batch model: processes message batches (classification/extraction) — cheap model works
AI_BATCH_MODEL=claude-haiku-4-20250506
# Summary model: writes the executive narrative after all batches complete
AI_SUMMARY_MODEL=claude-sonnet-4-20250514

# Contact Mapping - Define names for reports and their identifiers
# PERSON(x)_NAME: The name used in all reports (e.g., "John Doe")
# PERSON(x)_MAPPING: JSON array of identifiers to match (phones, emails, names, aliases)
# NOTE: Phone numbers are automatically expanded to common formats:
#   - "+12345678901" also matches "234-567-8901" and "(234) 567-8901"
#   - You only need to list each phone number once in any format
PERSON1_NAME="First Last"
PERSON1_MAPPING='[
    "+12345678901",
    "email@example.com",
    "FirstName",
    "Full Name"]'

PERSON2_NAME="Another Person"
PERSON2_MAPPING='[
    "+19876543210",
    "another@example.com",
    "AnotherName"]'

PERSON3_NAME="Third Person"
PERSON3_MAPPING='[
    "third@example.com",
    "ThirdName",
    "Nickname"]'

# AI Analysis Contacts — which mapped persons' conversations to send to AI
# JSON array of PERSON names. Only conversations where BOTH parties are in this
# list (plus 'Me') will be sent to Claude for analysis.
# Default (empty or omitted): all mapped persons
# Example: only analyze conversations with Person 2:
# AI_CONTACTS='["Another Person"]'
AI_CONTACTS=

# Data Sources (comment out or remove any sources you don't have)
# iMessage database (macOS only)
MESSAGES_DB_PATH=~/Library/Messages/chat.db
# WhatsApp exported chat directory (ZIP or .txt files)
WHATSAPP_SOURCE_DIR=~/workspace/data/forensic_message_analyzer/source_files/whatsapp/
# Screenshot directory for OCR processing
SCREENSHOT_SOURCE_DIR=~/workspace/data/forensic_message_analyzer/source_files/screenshots/
# Email directory (.eml and .mbox files)
EMAIL_SOURCE_DIR=~/workspace/data/forensic_message_analyzer/source_files/email/
# Microsoft Teams personal export directory (.tar archives)
TEAMS_SOURCE_DIR=~/workspace/data/forensic_message_analyzer/source_files/microsoft_teams_personal/
# Counseling session records directory (YAML metadata + optional PDFs)
COUNSELING_SOURCE_DIR=~/workspace/data/forensic_message_analyzer/source_files/counseling/

# Legal / Case Identification
# CASE_NUMBER may be either a single value OR a JSON array of strings for
# consolidated runs spanning multiple matters. CASE_NUMBERS (plural) is also
# accepted as a JSON array. All values are rendered one-per-line in reports.
# EXAMINER_NAME=Jane Doe
# CASE_NUMBER=2024-FL-12345
# CASE_NUMBER='["2024-FL-12345","2024-FL-67890"]'
# CASE_NUMBERS='["2024-FL-12345","2024-FL-67890"]'
# CASE_NAME=Smith v. Smith
# ORGANIZATION=Law Offices of Example

# -------------------------------------------------------------------
# Optional overrides (all have sensible defaults in code)
# Uncomment and change only if you need non-default values.
# -------------------------------------------------------------------
# AI_ENDPOINT=https://your-azure-endpoint.services.ai.azure.com
# ANALYSIS_TIMEZONE=America/Los_Angeles
# BATCH_SIZE=50
# USE_BATCH_API=true
# MAX_TOKENS_PER_REQUEST=4096
# THREAT_CONFIDENCE_THRESHOLD=0.5
# MANUAL_REVIEW_THRESHOLD=0.5
# OUTPUT_DIR=~/workspace/output/forensic_message_analyzer
# REVIEW_DIR=~/workspace/data/forensic_message_analyzer/review
# LOG_LEVEL=INFO

# iMessage database companion files (WAL mode)
# MESSAGES_DB_WAL=~/Library/Messages/chat.db-wal
# MESSAGES_DB_SHM=~/Library/Messages/chat.db-shm

# Date range filtering (ISO format)
# START_DATE=2024-01-01
# END_DATE=2024-12-31

# Analysis toggles
# MAX_RETRIES=3
# ENABLE_IMAGE_ANALYSIS=true
# ENABLE_SENTIMENT_ANALYSIS=true
# ENABLE_OCR=true

# Counseling session timeline correlation window (hours before/after each session)
# COUNSELING_CORRELATION_WINDOW_HOURS=48

# Rate limiting (synchronous API mode only)
# MAX_REQUESTS_PER_MINUTE=40
# TOKENS_PER_MINUTE=25000
# REQUEST_DELAY_MS=1500

# Content filter logging
# CONTENT_FILTER_LOG=~/workspace/logs/content_filter.log
