# Anthropic Claude Configuration
AI_API_KEY=your-api-key-here

# Two-model setup. AI_BATCH_MODEL handles per-message batch classification (cheap, high-volume); AI_SUMMARY_MODEL writes the executive narrative after batches complete (higher quality, single call).
# Supported models: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
# NOTE: claude-opus-4-6 is also supported but considered legacy by Anthropic. The only reason to prefer opus-4-6 over opus-4-7 is cost: opus-4-7 uses a new tokenizer that produces up to 35% more tokens for the same text, making it effectively ~35% more expensive despite identical $/MTok rates.
AI_BATCH_MODEL=claude-haiku-4-5
# Summary model: writes the executive narrative after all batches complete
AI_SUMMARY_MODEL=claude-sonnet-4-6

# Contact Mapping - Define names for reports and their identifiers
# PERSON(x)_NAME: The name used in all reports (e.g., "John Doe")
# PERSON(x)_MAPPING: JSON array of identifiers to match (phones, emails, names, aliases)
# NOTE: Phone numbers are automatically expanded to common formats:
#   - "+12345678901" also matches "234-567-8901" and "(234) 567-8901"
#   - You only need to list each phone number once in any format
PERSON1_NAME="First Last"
PERSON1_MAPPING='[
    "+12345678901",
    "email@example.com",
    "FirstName",
    "Full Name"]'

PERSON2_NAME="Another Person"
PERSON2_MAPPING='[
    "+19876543210",
    "another@example.com",
    "AnotherName"]'

PERSON3_NAME="Third Person"
PERSON3_MAPPING='[
    "third@example.com",
    "ThirdName",
    "Nickname"]'

# AI Analysis Contacts — which mapped persons' conversations to send to AI
# JSON array of PERSON names. Only conversations where BOTH parties are in this list (plus 'Me') will be sent to Claude for analysis.
# Default (empty or omitted): all mapped persons
# Example: only analyze conversations with Person 2:
# AI_CONTACTS='["Another Person"]'
AI_CONTACTS=

# Data Sources (comment out or remove any sources you don't have)
# iMessage database (macOS only)
MESSAGES_DB_PATH=~/Library/Messages/chat.db
# WhatsApp exported chat directory (ZIP or .txt files)
WHATSAPP_SOURCE_DIR=~/workspace/data/forensic-message-analyzer/source_files/whatsapp/
# Screenshot directory for OCR processing
SCREENSHOT_SOURCE_DIR=~/workspace/data/forensic-message-analyzer/source_files/screenshots/
# Email directory (.eml and .mbox files)
EMAIL_SOURCE_DIR=~/workspace/data/forensic-message-analyzer/source_files/email/
# Microsoft Teams personal export directory (.tar archives)
TEAMS_SOURCE_DIR=~/workspace/data/forensic-message-analyzer/source_files/microsoft_teams_personal/
# Counseling session records directory (YAML metadata + optional PDFs)
COUNSELING_SOURCE_DIR=~/workspace/data/forensic-message-analyzer/source_files/counseling/

# Legal / Case Identification
# CASE_NUMBER and CASE_NAME may each be a single value OR a JSON array of strings for consolidated runs spanning multiple matters. Plural forms (CASE_NUMBERS, CASE_NAMES) are also accepted as JSON arrays. All values render one-per-line in reports.
# EXAMINER_NAME=Jane Doe
# CASE_NUMBER=2024-FL-12345
# CASE_NUMBER='["2024-FL-12345","2024-FL-67890"]'
# CASE_NUMBERS='["2024-FL-12345","2024-FL-67890"]'
# CASE_NAME=Smith v. Smith
# CASE_NAME='["Smith v. Smith","Jones v. Jones"]'
# CASE_NAMES='["Smith v. Smith","Jones v. Jones"]'
# ORGANIZATION=Law Offices of Example

# -------------------------------------------------------------------
# Optional overrides (all have sensible defaults in code)
# Uncomment and change only if you need non-default values.
# -------------------------------------------------------------------
# Azure AI endpoint (omit for direct Anthropic API, which is the default)
# AI_ENDPOINT=https://your-azure-endpoint.services.ai.azure.com
# ANALYSIS_TIMEZONE=America/Los_Angeles
# BATCH_SIZE=50
# USE_BATCH_API=true
# MAX_TOKENS_PER_REQUEST=4096
# THREAT_CONFIDENCE_THRESHOLD=0.5
# MANUAL_REVIEW_THRESHOLD=0.5
# OUTPUT_DIR=~/workspace/output/forensic-message-analyzer
# REVIEW_DIR=~/workspace/data/forensic-message-analyzer/review
# REVIEW_PORT=5000       # Flask review UI port; override if 5000 is taken (macOS AirPlay Receiver) or to run two pipelines side by side
# LOG_LEVEL=INFO

# iMessage database companion files (WAL mode)
# MESSAGES_DB_WAL=~/Library/Messages/chat.db-wal
# MESSAGES_DB_SHM=~/Library/Messages/chat.db-shm

# Date range filtering (ISO format)
# START_DATE=2024-01-01
# END_DATE=2024-12-31

# Analysis toggles
# MAX_RETRIES=3
# ENABLE_IMAGE_ANALYSIS=true
# ENABLE_SENTIMENT_ANALYSIS=true
# ENABLE_OCR=true

# Counseling session timeline: how many hours before/after each session to include surrounding messages for context (default: 48)
# COUNSELING_CORRELATION_WINDOW_HOURS=48

# Rate limiting (synchronous API mode only)
# MAX_REQUESTS_PER_MINUTE=40
# TOKENS_PER_MINUTE=25000
# REQUEST_DELAY_MS=1500


# Contact auto-mapping. Directory of vCard (.vcf) exports; matching phone numbers and emails are merged into PERSON*_MAPPING before extraction runs, shrinking the "Unknown" third-party surface. Provenance of every auto-mapped entry is recorded in the chain of custody.
# CONTACTS_VCARD_DIR=~/workspace/data/forensic-message-analyzer/contacts/

# Examiner signing key (PEM-encoded Ed25519 private key) for detached signatures on the manifest, chain of custody, and final reports. When unset, a per-run ephemeral key is generated under run_dir/keys/ — still tamper-evident within the run but not anchored to a published examiner identity. For the strongest defensibility, generate a long-lived keypair out of band and publish the public cert.
# EXAMINER_SIGNING_KEY=~/workspace/data/forensic-message-analyzer/examiner_ed25519.pem
